  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "postgres", "uid": "cfp-postgres" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 50 }, { "color": "red", "value": 100 }] } }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Active connections",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cfp-postgres" },
          "rawSql": "SELECT count(*) AS value FROM pg_stat_activity WHERE state = 'active';",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "cfp-postgres" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 80 }, { "color": "green", "value": 95 }] }, "unit": "percent" }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Buffer cache hit rate",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cfp-postgres" },
          "rawSql": "SELECT round(100.0 * sum(blks_hit) / nullif(sum(blks_hit) + sum(blks_read), 0), 2) AS value FROM pg_stat_database;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "cfp-postgres" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Installed extensions",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cfp-postgres" },
          "rawSql": "SELECT count(*) AS value FROM pg_extension;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "cfp-postgres" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "User tables",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cfp-postgres" },
          "rawSql": "SELECT count(*) AS value FROM pg_stat_user_tables;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "cfp-postgres" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "seq_scans" }, "properties": [{ "id": "custom.width", "value": 90 }] },
          { "matcher": { "id": "byName", "options": "idx_scans" }, "properties": [{ "id": "custom.width", "value": 90 }] },
          { "matcher": { "id": "byName", "options": "live_rows" }, "properties": [{ "id": "custom.width", "value": 90 }] },
          { "matcher": { "id": "byName", "options": "dead_rows" }, "properties": [{ "id": "custom.width", "value": 90 }] }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "id": 5,
      "options": { "cellHeight": "sm", "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false }, "showHeader": true, "sortBy": [{ "desc": true, "displayName": "live_rows" }] },
      "title": "Table statistics",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cfp-postgres" },
          "rawSql": "SELECT schemaname AS schema, relname AS table, seq_scan AS seq_scans, idx_scan AS idx_scans, n_live_tup AS live_rows, n_dead_tup AS dead_rows, pg_size_pretty(pg_total_relation_size(relid)) AS total_size FROM pg_stat_user_tables ORDER BY n_live_tup DESC;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "cfp-postgres" },
      "fieldConfig": { "defaults": {} },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "id": 6,
      "options": { "cellHeight": "sm", "footer": { "show": false }, "showHeader": true },
      "title": "Active queries (pg_stat_activity)",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cfp-postgres" },
          "rawSql": "SELECT pid, usename AS user, application_name AS app, state, wait_event_type, wait_event, now() - query_start AS duration, left(query, 120) AS query FROM pg_stat_activity WHERE state != 'idle' AND pid != pg_backend_pid() ORDER BY duration DESC NULLS LAST;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "cfp-postgres" },
      "fieldConfig": { "defaults": {} },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "id": 7,
      "options": { "cellHeight": "sm", "footer": { "show": false }, "showHeader": true },
      "title": "Index usage",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cfp-postgres" },
          "rawSql": "SELECT schemaname AS schema, tablename AS table, indexname AS index, idx_scan AS scans, idx_tup_read AS tuples_read, idx_tup_fetch AS tuples_fetched, pg_size_pretty(pg_relation_size(indexrelid)) AS index_size FROM pg_stat_user_indexes ORDER BY idx_scan DESC;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "cfp-postgres" },
      "fieldConfig": { "defaults": {} },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "id": 8,
      "options": { "cellHeight": "sm", "footer": { "show": false }, "showHeader": true },
      "title": "Locks",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cfp-postgres" },
          "rawSql": "SELECT l.pid, a.usename AS user, l.locktype, l.relation::regclass AS relation, l.mode, l.granted, left(a.query, 100) AS query FROM pg_locks l JOIN pg_stat_activity a ON l.pid = a.pid WHERE NOT l.granted ORDER BY l.pid;",
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["postgresql", "learning"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "PostgreSQL Learning Overview",
  "uid": "pg-learning-overview",
